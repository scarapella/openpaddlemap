{
    "version": 8,
    "sources": {
        "trails": {
            "type": "vector",
            "tiles": [
                "https://tiles.openstreetmap.us/vector/trails/{z}/{x}/{y}.mvt"
            ],
            "minzoom": 0,
            "maxzoom": 14
        }
    },
    "sprite": "https://opentrailmap.us/style/sprites/opentrailmap",
    "layers": [
        {
            "id": "poi-campsites",
            "type": "symbol",
            "source": "trails",
            "source-layer": "trail_poi",
            "minzoom": 10,
            "filter": [
                "==",
                [
                    "get",
                    "tourism"
                ],
                "camp_site"
            ],
            "layout": {
                "icon-image": "campground",
                "icon-size": 0.8,
                "icon-allow-overlap": false
            }
        },
        {
            "id": "poi-caravan-sites",
