{
    "version": 8,
    "sources": {
        "trails": {
            "type": "vector",
            "tiles": [
                "https://tiles.openstreetmap.us/vector/trails/{z}/{x}/{y}.mvt"
            ],
            "minzoom": 0,
            "maxzoom": 14
        }
    },
    "sprite": "https://opentrailmap.us/style/sprites/opentrailmap",
    "layers": [
        {
            "id": "waterways",
            "type": "line",
            "source": "trails",
            "source-layer": "trail",
            "minzoom": 5,
            "filter": [
                "all",
                [
                    "has",
                    "waterway"
                ],
                [
                    "in",
                    [
                        "get",
                        "canoe"
                    ],
                    [
                        "literal",
                        [
                            "yes",
                            "designated"
                        ]
                    ]
                ]
            ],
            "layout": {
                "line-cap": "round",
                "line-join": "round"
            },
            "paint": {
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    12,
                    1,
                    22,
                    5
                ],
                "line-color": "#003b93"
            }
        },
        {
            "id": "paths",
            "type": "line",
            "source": "trails",
            "source-layer": "trail",
            "minzoom": 5,
            "filter": [
                "all",
                [
                    "has",
                    "highway"
                ],
                [
                    "in",
                    [
                        "get",
                        "portage"
                    ],
                    [
                        "literal",
                        [
                            "yes",
                            "designated"
                        ]
                    ]
                ]
            ],
            "layout": {
                "line-cap": "round",
                "line-join": "round"
            },
            "paint": {
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    12,
                    1,
                    22,
                    5
                ],
                "line-color": "#4f2e28"
            }
        }
    ]
}